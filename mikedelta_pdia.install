use Drupal\node\Entity\NodeType;
use Drupal\field\Entity\FieldStorageConfig;
use Drupal\field\Entity\FieldConfig;
use Drupal\Core\Site\Settings;
use Drupal\Core\Field\Entity\BaseFieldOverride;

/**
 * Implements hook_install().
 */
function mikedelta_pdia_install() {
  
  $private_path = Settings::get('file_private_path');
  $uri_scheme = !empty($private_path) ? 'private' : 'public';

  // 1. Cria o Tipo de Conteúdo 'md_pdia'
  if (!NodeType::load('md_pdia')) {
    NodeType::create([
      'type' => 'md_pdia',
      'name' => 'Plano do Dia (MikeDelta PDia)',
      'description' => 'Cadastro de arquivos PDF para o Plano do Dia.',
      'display_submitted' => FALSE,
    ])->save();
    $promote_override = BaseFieldOverride::create([
      'field_name' => 'promote',
      'entity_type' => 'node',
      'bundle' => 'md_pdia',
    ]);
    $promote_override->setDefaultValue(FALSE);
    $promote_override->save();
  }

  // 2. Cria a estrutura do campo 'Data'
  if (!FieldStorageConfig::loadByName('node', 'field_data')) {
    FieldStorageConfig::create([
      'field_name' => 'field_data',
      'entity_type' => 'node',
      'type' => 'datetime',
      'settings' => ['datetime_type' => 'date'],
    ])->save();
  }
  
  if (!FieldConfig::loadByName('node', 'md_pdia', 'field_data')) {
    FieldConfig::create([
      'field_name' => 'field_data',
      'entity_type' => 'node',
      'bundle' => 'md_pdia',
      'label' => 'Data',
      'required' => TRUE,
    ])->save();
  }

  // 3. Cria a estrutura do campo 'Arquivo'
  if (!FieldStorageConfig::loadByName('node', 'field_arquivo')) {
    FieldStorageConfig::create([
      'field_name' => 'field_arquivo',
      'entity_type' => 'node',
      'type' => 'file',
      'settings' => [
        'uri_scheme' => $uri_scheme,
      ],
    ])->save();
  }

  if (!FieldConfig::loadByName('node', 'md_pdia', 'field_arquivo')) {
    FieldConfig::create([
      'field_name' => 'field_arquivo',
      'entity_type' => 'node',
      'bundle' => 'md_pdia',
      'label' => 'Arquivo PDF',
      'required' => TRUE,
      'settings' => [
        'file_extensions' => 'pdf',
        'file_directory' => 'md_pdia/[date:custom:Y]/[date:custom:m]',
      ],
    ])->save();
  }

  // 4. Configura a exibição do formulário
  $form_display = \Drupal::entityTypeManager()
    ->getStorage('entity_form_display')
    ->load('node.md_pdia.default');
  
  if (!$form_display) {
    $form_display = \Drupal::entityTypeManager()
      ->getStorage('entity_form_display')
      ->create([
        'targetEntityType' => 'node',
        'bundle' => 'md_pdia',
        'mode' => 'default',
        'status' => TRUE,
      ]);
  }
  
  $form_display->setComponent('field_data', [
    'type' => 'datetime_default',
    'weight' => 1,
  ])
  ->setComponent('field_arquivo', [
    'type' => 'file_generic',
    'weight' => 2,
  ])
  ->save();

  // 5. Exibe a mensagem de sucesso
  $messenger = \Drupal::messenger();
  if ($uri_scheme === 'private') {
    $messenger->addStatus(t('Módulo instalado com sucesso. O campo de upload foi configurado para usar o Diretório Privado do sistema - private://'));
  } else {
    $messenger->addWarning(t('Módulo instalado com sucesso. NOTA: Nenhum diretório privado foi detectado no settings.php. Os PDFs usarão o diretório público - public://'));
  }
}

/**
 * Implements hook_requirements().
 */
function mikedelta_pdia_requirements($phase) {
  $requirements = [];
  
  if ($phase == 'runtime') {
    if (!class_exists('\ZipArchive')) {
      $requirements['mikedelta_pdia_zip'] = [
        'title' => t('PHP ZipArchive (MikeDelta PDia)'),
        'value' => t('Não instalado'),
        'description' => t('A extensão <strong>php-zip</strong> do PHP é obrigatória para executar as rotinas de Importação e Exportação de backups do Plano do Dia. Habilite a extensão <strong>php-zip</strong> no servidor.'),
        'severity' => REQUIREMENT_ERROR,
      ];
    } else {
      $requirements['mikedelta_pdia_zip'] = [
        'title' => t('PHP ZipArchive (MikeDelta PDia)'),
        'value' => t('Instalado e Ativo'),
        'severity' => REQUIREMENT_OK,
      ];
    }
  }
  
  return $requirements;
}

/**
 * Implements hook_uninstall().
 */
function mikedelta_pdia_uninstall() {
  
  $storage_handler = \Drupal::entityTypeManager()->getStorage('node');
  $nodes = $storage_handler->loadByProperties(['type' => 'md_pdia']);
  if (!empty($nodes)) {
    $storage_handler->delete($nodes);
  }

  $content_type = NodeType::load('md_pdia');
  if ($content_type) {
    $content_type->delete();
  }

  $field_data = FieldStorageConfig::loadByName('node', 'field_data');
  if ($field_data) {
    $field_data->delete();
  }

  $field_arquivo = FieldStorageConfig::loadByName('node', 'field_arquivo');
  if ($field_arquivo) {
    $field_arquivo->delete();
  }

  $database = \Drupal::database();

  $query = $database->select('file_usage', 'fu')
    ->fields('fu', ['fid'])
    ->condition('module', 'mikedelta_pdia')
    ->execute();

  $fids = $query->fetchCol();

  if (!empty($fids)) {
    $file_storage = \Drupal::entityTypeManager()->getStorage('file');
    $files = $file_storage->loadMultiple($fids);
    
    foreach ($files as $file) {
      $file->delete();
    }
  }

  \Drupal::configFactory()->getEditable('mikedelta_pdia.settings')->delete();
}